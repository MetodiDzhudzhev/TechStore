<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />

	<title>@ViewData["Title"] - TechStore</title>

	<link rel="stylesheet" href="~/css/Layout/reset.css" asp-append-version="true" />
	<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

	<link rel="stylesheet" href="~/css/Layout/navbar.css" asp-append-version="true" />
	<link rel="stylesheet" href="~/css/Layout/category-dropdown.css" asp-append-version="true" />
	<link rel="stylesheet" href="~/css/Layout/authentication-menu.css" asp-append-version="true" />

	<link rel="stylesheet" href="~/css/Components/cart-icon.css" asp-append-version="true" />

	<link rel="icon" type="image/svg+xml" href="~/favicon.svg" />

	<link rel="stylesheet"
		  href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />

	@await RenderSectionAsync("Styles", required: false)

</head>

<body class="layout">

	<header class="navbar">

		<div class="navbar__container">

			<a class="navbar__brand"
			   asp-area=""
			   asp-controller="Home"
			   asp-action="Index">

				<i class="bi bi-cpu"></i>
				<span>TechStore</span>
			</a>

			<div class="navbar__content">

				<div class="navbar__left">

					@await Component.InvokeAsync("CategoryDropdown")

					<form class="navbar__search"
						  asp-area=""
						  asp-controller="Product"
						  asp-action="Search"
						  method="get">

						<input class="navbar__search-input"
							   type="search"
							   placeholder="Search..."
							   name="query" />

						<button class="navbar__search-button" type="submit">
							<i class="bi bi-search"></i>
						</button>
					</form>

					@if (User.IsInRole("Admin") || User.IsInRole("Manager"))
					{
						<a class="navbar__link"
						   asp-area="ControlPanel"
						   asp-controller="Home"
						   asp-action="Index">
							Control Panel
						</a>
					}
				</div>

				<div class="navbar__right">

					<partial name="_LoginPartial" />
				</div>
			</div>
		</div>
	</header>

	<main class="layout__main">

		@if (TempData["ErrorMessage"] != null)
		{
			<div class="layout__alert">
				@TempData["ErrorMessage"]
			</div>
		}

		@RenderBody()
	</main>

	<footer class="footer">

		<div class="footer__content">

			© @DateTime.UtcNow.Year - TechStore
			<br />
			Thank you for shopping with us!
		</div>
	</footer>

	<script src="~/js/Layout/navbar.js"></script>
	<script src="~/js/Layout/category-dropdown.js"></script>
	<script src="~/js/Layout/authentication-menu.js"></script>

	@await RenderSectionAsync("Scripts", required: false)
</body>
</html>