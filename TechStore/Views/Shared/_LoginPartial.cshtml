<ul class="auth-menu">

    @if (User.Identity?.IsAuthenticated == true)
    {
        <li class="auth-menu__item auth-menu__item--cart">
            @await Component.InvokeAsync("CartCount")
        </li>

        <li class="auth-menu__item auth-menu__item--profile">

            <button class="profile-toggle"
                    id="profileToggle"
                    aria-expanded="false"
                    aria-haspopup="true"
                    title="My profile">

                <i class="bi bi-person-circle profile-toggle__icon"></i>
            </button>

            <div class="profile-dropdown" id="profileDropdown">

                <div class="profile-dropdown__header">

                    <span class="profile-dropdown__label">
                        Signed in as
                    </span>

                    <strong class="profile-dropdown__username">
                        @User.Identity?.Name
                    </strong>

                </div>

                <nav class="profile-dropdown__menu">

                    <a asp-area="Account"
                       asp-controller="Account"
                       asp-action="MyOrders"
                       class="profile-dropdown__link">

                        <i class="bi bi-receipt"></i>
                        <span>My orders</span>
                    </a>

                    <a asp-area="Account"
                       asp-controller="Account"
                       asp-action="MyReviews"
                       class="profile-dropdown__link">

                        <i class="bi bi-star"></i>
                        <span>My reviews</span>
                    </a>

                    <a asp-area="Account"
                       asp-controller="Account"
                       asp-action="DeliveryDetails"
                       class="profile-dropdown__link">

                        <i class="bi bi-box-seam"></i>
                        <span>Delivery details</span>
                    </a>
                </nav>
            </div>
        </li>

        <li class="auth-menu__item">

            <form asp-area="Identity"
                  asp-page="/Account/Logout"
                  asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">

                <button type="submit"
                        class="auth-menu__logout">
                    Logout
                </button>
            </form>
        </li>
    }
    else
    {
        <li class="auth-menu__item">

            <a asp-area="Identity"
               asp-page="/Account/Register"
               class="auth-menu__link">
                Register
            </a>

        </li>

        <li class="auth-menu__item">

            <a asp-area="Identity"
               asp-page="/Account/Login"
               class="auth-menu__link">
                Login
            </a>
        </li>
    }
</ul>
