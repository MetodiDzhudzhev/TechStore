@model TechStore.Web.ViewModels.Payment.PaymentSummaryViewModel

@{
    ViewData["Title"] = "Payment";
}

<section class="payment">
    <div class="payment__card">

        <header class="payment__header">
            <h2 class="payment__title">Payment</h2>
        </header>

        <div class="payment__summary">

            <p class="payment__order">
                <span class="payment__label">Order # <span class="payment__value">@Model.OrderId</span></span>
            </p>

            <div class="payment__info">
                <span class="payment__label">Recipient</span>
                <span class="payment__value">@Model.RecipientName</span>
            </div>

            <div class="payment__info">
                <span class="payment__label">Email</span>
                <span class="payment__value">@Model.Email</span>
            </div>

            <div class="payment__info">
                <span class="payment__label">Shipping Address</span>
                <span class="payment__value">@Model.ShippingAddress</span>
            </div>

            <div class="payment__total">
                Total: @Model.TotalAmount.ToString("F2") €
            </div>
        </div>

        <div class="payment__actions">

            <form asp-controller="Payment"
                  asp-action="ConfirmCashOnDelivery"
                  method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="orderId" value="@Model.OrderId" />
                <button type="submit"
                        class="btn btn--outline btn--lg">
                    Cash on delivery
                </button>
            </form>

            <form asp-controller="Payment"
                  asp-action="CreateCheckoutSession"
                  method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="orderId" value="@Model.OrderId" />
                <button type="submit"
                        class="btn btn--primary btn--lg">
                    Pay with card
                </button>
            </form>
        </div>
    </div>
</section>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/payment.css" asp-append-version="true" />
}