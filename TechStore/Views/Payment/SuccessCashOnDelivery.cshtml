@model long

@{
    ViewData["Title"] = "Order Confirmed";
}

<section class="success">
    <div class="success__card">

        <div class="success__icon">
            ✓
        </div>

        <h2 class="success__title">
            Order <span class="success__order">#@Model</span> has been placed successfully.
        </h2>

        <p class="success__message">
            Thank you for shopping with us!
        </p>

        <div class="success__actions">

            <a asp-controller="Category"
               asp-action="Index"
               class="btn btn--primary btn--lg">
                Continue shopping
            </a>

            <a asp-area="Account"
               asp-controller="Account"
               asp-action="MyOrders"
               class="btn btn--outline btn--lg">
                View my orders
            </a>
        </div>
    </div>
</section>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/successCashOnDelivery.css" asp-append-version="true" />
}