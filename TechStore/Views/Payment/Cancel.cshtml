@model TechStore.Web.ViewModels.Payment.PaymentCancelViewModel

@{
    ViewData["Title"] = "Payment cancelled";
}

<section class="cancel">
    <div class="cancel__card">

        <h2 class="cancel__heading">
            Payment cancelled
        </h2>

        <p class="cancel__text">
            Your payment was not completed. No charges were made.
        </p>

        <p class="cancel__order">
            <strong>Order #</strong>@Model.OrderId
        </p>

        <div class="cancel__actions">
            <a asp-controller="Payment"
               asp-action="Payment"
               asp-route-id="@Model.OrderId"
               class="btn btn--outline">
                Back to order
            </a>

            <a asp-controller="Home"
               asp-action="Index"
               class="btn btn--primary">
                Back to Home
            </a>
        </div>
    </div>
</section>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/cancel-stripe.css" asp-append-version="true" />
}