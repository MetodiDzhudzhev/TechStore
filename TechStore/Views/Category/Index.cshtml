@using TechStore.Web.ViewModels.Category
@model IEnumerable<AllCategoriesIndexViewModel>

@{
    ViewData["Title"] = "Categories";
}

<section class="categories">

    <header class="categories__header">
        <h2 class="categories__title">@ViewData["Title"]</h2>

        @if (User?.Identity?.IsAuthenticated == true &&
                (User.IsInRole("Manager") || User.IsInRole("Admin")))
        {
            <a asp-area="ControlPanel"
               asp-controller="ControlPanelCategory"
               asp-action="Add"
               class="btn btn--primary">
                <span>Add Category</span>
            </a>
        }
    </header>

    <div class="categories__divider"></div>

    <div class="categories__grid">
        @foreach (var category in Model)
        {
            <article class="category-card">

                <div class="category-card__image-wrapper">
                    @if (!string.IsNullOrEmpty(category.ImageUrl))
                    {
                        <img src="@category.ImageUrl"
                             alt="@category.Name"
                             class="category-card__image" />
                    }
                    else
                    {
                        <img src="~/images/default-image.jpg"
                             alt="No Image Available"
                             class="category-card__image" />
                    }
                </div>

                <div class="category-card__body">

                    <h3 class="category-card__title">
                        @category.Name
                    </h3>

                    <div class="category-card__actions">

                        <a asp-controller="Product"
                           asp-action="IndexByCategory"
                           asp-route-categoryId="@category.Id"
                           class="btn btn--accent">
                            <i class="bi bi-search"></i>
                            <span>Explore</span>
                        </a>

                        @if (User?.Identity?.IsAuthenticated == true &&
                                            (User.IsInRole("Manager") || User.IsInRole("Admin")))
                        {
                            <div class="category-card__admin-actions">

                                <a asp-area="ControlPanel"
                                   asp-controller="ControlPanelCategory"
                                   asp-action="Edit"
                                   asp-route-categoryId="@category.Id"
                                   class="icon-btn icon-btn--edit"
                                   title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>

                                <a asp-area="ControlPanel"
                                   asp-controller="ControlPanelCategory"
                                   asp-action="Delete"
                                   asp-route-id="@category.Id"
                                   class="icon-btn icon-btn--delete"
                                   title="Delete">
                                    <i class="bi bi-trash"></i>
                                </a>

                            </div>
                        }
                    </div>
                </div>
            </article>
        }
    </div>
</section>

@section Styles {
    <link rel="stylesheet" href="~/css/Category/index.css" asp-append-version="true" />
}