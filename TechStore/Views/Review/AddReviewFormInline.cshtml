@model TechStore.Web.ViewModels.Review.ReviewFormInputModel

<form asp-controller="Review"
      asp-action="Add"
      method="post"
      class="review-form">

    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="ProductId" />

    <div class="review-form__group">
        <label class="review-form__label">
            Rating
        </label>

        <div class="review-form__rating">
            @for (int i = 5; i >= 1; i--)
            {
                <input asp-for="Rating"
                       type="radio"
                       id="star-inline-@i"
                       value="@i"
                       class="review-form__rating-input" />

                <label for="star-inline-@i"
                       class="review-form__star"
                       title="@i stars">
                    ★
                </label>
            }
        </div>

        <span asp-validation-for="Rating"
              class="review-form__error"></span>
    </div>

    <div class="review-form__group">
        <textarea asp-for="Comment"
                  rows="3"
                  placeholder="Write a comment..."
                  class="review-form__textarea"></textarea>

        <span asp-validation-for="Comment"
              class="review-form__error"></span>
    </div>

    <button type="submit"
            class="review-form__submit">
        Submit
    </button>
</form>