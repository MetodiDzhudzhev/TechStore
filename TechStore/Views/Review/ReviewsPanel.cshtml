@using TechStore.Web.ViewModels.Review;
@model ReviewsPanelViewModel

<div class="reviews">

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="reviews__message reviews__message--error">
            @TempData["ErrorMessage"]
        </div>
    }

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="reviews__message reviews__message--success">
            @TempData["SuccessMessage"]
        </div>
    }

    <div data-total-count="@Model.TotalCount"
         data-average-rating="@Model.AverageRating"
         class="reviews__meta">
    </div>

    @if (User.Identity?.IsAuthenticated == true && Model.CanAddReview)
    {
        <div class="reviews__add">
            <div class="reviews__add-title">
                Add review
            </div>

            @await Html.PartialAsync(
            "~/Views/Review/AddReviewFormInline.cshtml",
                new TechStore.Web.ViewModels.Review.ReviewFormInputModel { ProductId = Model.ProductId })
    </div>
        }
    else if (User.Identity?.IsAuthenticated != true)
    {
        <div class="reviews__message reviews__message--info">
            <a asp-area="Identity" asp-page="/Account/Login">
                Login to add a review.
            </a>
        </div>
    }

    @if (!Model.Items.Any())
    {
        <p class="reviews__empty">
            No reviews yet.
        </p>
    }
    else
    {
        <div class="reviews__list">

            @foreach (var review in Model.Items)
            {
                <div class="review">

                    <div class="review__header">
                        <span class="review__author">
                            @review.UserName
                        </span>

                        <span class="review__date">
                            @review.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy")
                        </span>
                    </div>

                    <div class="review__rating">
                        @for (int i = 1; i <= 5; i++)
                        {
                            if (i <= review.Rating)
                            {
                                <span class="review__star review__star--filled">★</span>
                            }
                            else
                            {
                                <span class="review__star">☆</span>
                            }
                        }
                    </div>

                    @if (!string.IsNullOrWhiteSpace(review.Comment))
                    {
                        <p class="review__comment">
                            @review.Comment
                        </p>
                    }
                </div>
            }

        </div>

        <div class="reviews__pagination">

            <button class="reviews__page-btn @(Model.CurrentPage == 1 ? "reviews__page-btn--disabled" : "")"
                    data-page="@(Model.CurrentPage - 1)">
                Previous
            </button>

            @for (int p = 1; p <= Model.TotalPages; p++)
            {
                <button class="reviews__page-btn @(p == Model.CurrentPage ? "reviews__page-btn--active" : "")"
                        data-page="@p">
                    @p
                </button>
            }

            <button class="reviews__page-btn @(Model.CurrentPage == Model.TotalPages ? "reviews__page-btn--disabled" : "")"
                    data-page="@(Model.CurrentPage + 1)">
                Next
            </button>

        </div>
    }

</div>