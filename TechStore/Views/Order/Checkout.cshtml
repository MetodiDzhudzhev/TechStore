@model TechStore.Web.ViewModels.Order.OrderDeliveryDetailsViewModel

@{
    ViewData["Title"] = "Delivery details";
}

<section class="checkout">
    <div class="checkout__card">

        <header class="checkout__header">
            <h2 class="checkout__title">Delivery details</h2>
        </header>

        <form asp-action="Checkout"
              method="post"
              class="checkout__form"
              novalidate>

            @Html.AntiForgeryToken()

            <div class="field">
                <label asp-for="RecipientName" class="field__label"></label>
                <input asp-for="RecipientName"
                       class="field__input"
                       placeholder="Enter recipient name" />
                <span asp-validation-for="RecipientName"
                      class="field__error"></span>
            </div>

            <div class="field">
                <label asp-for="PhoneNumber" class="field__label"></label>
                <input asp-for="PhoneNumber"
                       class="field__input"
                       placeholder="Enter phone number" />
                <span asp-validation-for="PhoneNumber"
                      class="field__error"></span>
            </div>

            <div class="field">
                <label asp-for="Email" class="field__label"></label>
                <input asp-for="Email"
                       class="field__input"
                       placeholder="Enter email address" />
                <span asp-validation-for="Email"
                      class="field__error"></span>
            </div>

            <div class="field field--last">
                <label asp-for="ShippingAddress" class="field__label"></label>
                <input asp-for="ShippingAddress"
                       class="field__input"
                       placeholder="Enter shipping address" />
                <span asp-validation-for="ShippingAddress"
                      class="field__error"></span>
            </div>

            <div class="checkout__actions">
                <a asp-controller="Cart"
                   asp-action="Index"
                   class="btn btn--outline btn--lg">
                    Back to Cart
                </a>

                <button type="submit"
                        class="btn btn--primary btn--lg">
                    Proceed to Payment
                </button>
            </div>

        </form>
    </div>
</section>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/checkout.css" asp-append-version="true" />
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}