@using TechStore.Web.ViewModels.Brand
@model BrandDetailsViewModel

@{
    ViewData["Title"] = "Brand Details";
}

<div class="brand-details">

    <div class="brand-details__card">

        <div class="brand-details__layout">

            <div class="brand-details__logo-wrapper">
                @if (!string.IsNullOrWhiteSpace(Model.logoUrl))
                {
                    <img src="@Model.logoUrl"
                         alt="@Model.Name Logo"
                         class="brand-details__logo" />
                }
                else
                {
                    <img src="~/images/default-brand.png"
                         alt="No Logo"
                         class="brand-details__logo" />
                }
            </div>

            <div class="brand-details__content">

                <h1 class="brand-details__title">
                    @Model.Name
                </h1>

                @if (!string.IsNullOrWhiteSpace(Model.Description))
                {
                    <p class="brand-details__description">
                        @Model.Description
                    </p>
                }
                else
                {
                    <p class="brand-details__description brand-details__description--empty">
                        No description available.
                    </p>
                }
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/Brand/details.css" />
}