@using TechStore.Web.ViewModels.Product
@model ProductDetailsViewModel

@{
    ViewData["Title"] = "Product Details";
}

<div class="product-details">
    <div class="product-details__card">
        <div class="product-details__layout">

            <div class="product-details__image-wrapper">
                <img src="@Model.ImageUrl"
                     alt="@Model.Name"
                     class="product-details__image" />
            </div>

            <div class="product-details__info">
                <h1 class="product-details__title">@Model.Name</h1>

                <p class="product-details__brand">
                    <span class="product-details__label">Brand:</span>
                    <a asp-controller="Brand"
                       asp-action="Details"
                       asp-route-id="@Model.BrandId"
                       class="product-details__brand-link">
                        @Model.Brand
                    </a>
                </p>

                <p class="product-details__description">
                    @Model.Description
                </p>

                <div class="product-details__price">
                    Price: <span>@Model.Price €</span>
                </div>

                @if (User?.Identity?.IsAuthenticated == true)
                {
                    <form asp-controller="Cart"
                          asp-action="Add"
                          method="post"
                          class="product-details__cart-form">
                        <input type="hidden" name="productId" value="@Model.Id" />

                        <input type="number"
                               name="quantity"
                               value="1"
                               min="1"
                               max="@Model.QuantityInStock"
                               class="product-details__quantity-input" />

                        <button type="submit" class="product-details__btn product-details__btn--add">
                            Add to cart
                        </button>
                    </form>
                }

                <p class="product-details__stock">
                    In stock: @Model.QuantityInStock pcs
                </p>

                <div class="product-details__actions">

                    @if (User?.Identity?.IsAuthenticated == true &&
                                        (User.IsInRole("Manager") || User.IsInRole("Admin")))
                    {
                        <a asp-area="ControlPanel"
                           asp-controller="ControlPanelProduct"
                           asp-action="Edit"
                           asp-route-id="@Model.Id"
                           class="product-details__btn product-details__btn--edit"
                           title="Edit">
                            <i class="bi bi-pencil"></i>
                        </a>

                        <a asp-area="ControlPanel"
                           asp-controller="ControlPanelProduct"
                           asp-action="Delete"
                           asp-route-id="@Model.Id"
                           class="product-details__btn product-details__btn--delete"
                           title="Delete">
                            <i class="bi bi-trash"></i>
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>

    <div id="reviews" class="reviews-panel">
        <div class="reviews-panel__card">

            <button class="reviews-panel__toggle"
                    type="button"
                    id="reviewsToggleBtn"
                    data-product-id="@Model.Id">

                <div class="reviews-panel__toggle-content">
                    <div>
                        <strong>Reviews</strong>
                        <span id="reviewsSummary"
                              class="reviews-panel__summary"></span>
                    </div>

                    <span class="reviews-panel__arrow">&#8595;</span>
                </div>
            </button>

            <div id="reviewsCollapse"
                 class="reviews-panel__collapse">

                <div id="reviewsContainer"
                     class="reviews-panel__container">

                    <div class="reviews-panel__loader"></div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/Product/product-details.css" />
    <link rel="stylesheet" href="~/css/Product/product-reviews.css" />
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/Product/product-details.js"></script>
}