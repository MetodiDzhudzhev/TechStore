@using TechStore.Web.ViewModels.Product
@model ProductsByCategoryViewModel

@{
    ViewData["Title"] = $"Products in {Model.CategoryName}";
}

<section class="category-products">

    <header class="category-products__header">
        <h2 class="category-products__title">
            @ViewData["Title"]
        </h2>

        @if (User?.Identity?.IsAuthenticated == true &&
                (User.IsInRole("Manager") || User.IsInRole("Admin")))
        {
            <a asp-area="ControlPanel"
               asp-controller="ControlPanelProduct"
               asp-action="Add"
               asp-route-categoryId="@Model.CategoryId"
               class="category-products__add-btn">
                <i class="fas fa-plus"></i>
                <span>Add product</span>
            </a>
        }
    </header>

    <div class="category-products__divider"></div>

    <div class="category-products__content">

        <form method="get" class="category-products__sort-form">
            <input type="hidden" name="categoryId" value="@Model.CategoryId" />

            <label class="category-products__sort-label">
                Sort by:
            </label>

            <select name="sort"
                    class="category-products__sort-select"
                    data-auto-submit>

                <option value="@ProductSort.NameAsc"
                        selected="@(Model.Sort == ProductSort.NameAsc)">
                    Name
                </option>

                <option value="@ProductSort.PriceAsc"
                        selected="@(Model.Sort == ProductSort.PriceAsc)">
                    Price ↑
                </option>

                <option value="@ProductSort.PriceDesc"
                        selected="@(Model.Sort == ProductSort.PriceDesc)">
                    Price ↓
                </option>
            </select>
        </form>

        @if (!Model.Products.Any())
        {
            <div class="category-products__empty">
                There are no products in this category.
            </div>
        }
        else
        {
            <div class="category-products__list">

                @foreach (var product in Model.Products)
                {
                    <article class="product-card">

                        <div class="product-card__image-wrapper">
                            <img src="@product.ImageUrl"
                                 alt="@product.Name"
                                 class="product-card__image" />
                        </div>

                        <div class="product-card__content">
                            <h4 class="product-card__title">
                                @product.Name
                            </h4>

                            <div class="product-card__meta">
                                <div class="product-card__price">
                                    <span class="product-card__label">Price:</span>
                                    @product.Price.ToString("F2") €
                                </div>

                                <div class="product-card__stock">
                                    <span class="product-card__label">Quantity in stock:</span>
                                    @product.QuantityInStock
                                </div>
                            </div>

                            <a asp-controller="Product"
                               asp-action="Details"
                               asp-route-id="@product.Id"
                               class="product-card__details-btn">
                                View details
                            </a>
                        </div>
                    </article>
                }
            </div>
        }

        <div class="category-products__footer">
            <a asp-controller="Category"
               asp-action="Index"
               class="category-products__back-btn">
                <i class="fas fa-arrow-left"></i>
                <span>Back to categories</span>
            </a>
        </div>
    </div>

</section>

@section Styles {
    <link rel="stylesheet" href="~/css/Product/index-by-category.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/Product/index-by-category.js" asp-append-version="true"></script>
}