@using TechStore.Web.ViewModels.Product
@model IEnumerable<ProductInCategoryViewModel>

@{
    ViewData["Title"] = "Search Results";
}

<div class="search-results">

    <header class="search-results__header">
        <h2 class="search-results__title">
            @ViewData["Title"]
        </h2>

        @if (!string.IsNullOrWhiteSpace(ViewBag.Query))
        {
            <p class="search-results__query">
                Showing results for:
                <span>@ViewBag.Query</span>
            </p>
        }
    </header>

    @if (!string.IsNullOrWhiteSpace(ViewBag.Message))
    {
        <div class="search-results__message--warning">
            @ViewBag.Message
        </div>
    }

    <div class="search-results__divider"></div>

    @if (!Model.Any() && string.IsNullOrWhiteSpace(ViewBag.Message))
    {
        <div class="search-results__message--blank">
            No products found matching your search.
        </div>
    }
    else
    {
        <div class="category-products__list">

            @foreach (var product in Model)
            {
                <article class="product-card">

                    <div class="product-card__image-wrapper">
                        <img src="@product.ImageUrl"
                             alt="@product.Name"
                             class="product-card__image" />
                    </div>

                    <div class="product-card__content">
                        <h4 class="product-card__title">
                            @product.Name
                        </h4>

                        <div class="product-card__meta">
                            <div class="product-card__price">
                                <span class="product-card__label">Price:</span>
                                @product.Price.ToString("F2") €
                            </div>

                            <div class="product-card__stock">
                                <span class="product-card__label">Quantity in stock:</span>
                                @product.QuantityInStock
                            </div>
                        </div>

                        <a asp-controller="Product"
                           asp-action="Details"
                           asp-route-id="@product.Id"
                           class="product-card__details-btn">
                            View details
                        </a>
                    </div>
                </article>
            }

        </div>
    }
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/Product/search.css" />
    <link rel="stylesheet" href="~/css/Product/index-by-category.css" />
}