@using TechStore.Web.ViewModels.Review
@model ReviewManageListViewModel

@{
    ViewData["Title"] = "Manage Reviews";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert--success">
        @TempData["SuccessMessage"]
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert--error">
        @TempData["ErrorMessage"]
    </div>
}

<section class="manage-reviews">

    <header class="manage-reviews__header">
        <h2 class="manage-reviews__title">Manage Reviews</h2>
    </header>


    @if (Model.Reviews == null || !Model.Reviews.Any())
    {
        <div class="manage-reviews__empty">
            No reviews found.
        </div>
    }
    else
    {

        <div class="review-list">

            @foreach (var review in Model.Reviews)
            {
                var collapseId = $"review-{review.ReviewId}";

                <article class="review-card">

                    <div class="review-card__summary">

                        <div class="review-card__meta">

                            <span class="review-card__id">
                                Review #@review.ReviewId
                            </span>

                            <span class="review-card__date">
                                @review.CreatedAt
                            </span>

                            <span class="review-rating review-rating--@review.Rating">
                                Rating: @review.Rating / 5
                            </span>

                            <span class="review-card__separator">|</span>

                            <span class="review-card__author">
                                @review.Author
                            </span>
                        </div>

                        <div class="review-card__actions">

                            <button class="btn btn--details js-review-toggle"
                                    data-target="@collapseId">
                                <span class="btn-text">Details</span>
                            </button>

                            <form asp-area="ControlPanel"
                                  asp-controller="ControlPanelReview"
                                  asp-action="Delete"
                                  asp-route-id="@review.ReviewId"
                                  method="post">

                                @Html.AntiForgeryToken()

                                <button type="submit"
                                        class="btn btn--delete"
                                        onclick="return confirm('Are you sure you want to delete Review #@review.ReviewId?');">
                                    Delete
                                </button>
                            </form>
                        </div>
                    </div>

                    <div id="@collapseId" class="review-card__details">

                        <div class="review-comment">

                            <div class="review-comment__title">
                                Comment
                            </div>

                            @if (!string.IsNullOrWhiteSpace(review.Comment))
                            {
                                <div class="review-comment__text">
                                    @review.Comment
                                </div>
                            }
                            else
                            {
                                <div class="review-comment__empty">
                                    No comment provided.
                                </div>
                            }
                        </div>

                        <div class="review-product">

                            <div class="review-product__title">
                                Product
                            </div>

                            <a asp-area=""
                               asp-controller="Product"
                               asp-action="Details"
                               asp-route-id="@review.ProductId"
                               class="review-product__link">

                                <div class="product-mini">

                                    <img src="@(!string.IsNullOrWhiteSpace(review.ProductImage) ? review.ProductImage : Url.Content("~/images/default-image.jpg"))"
                                         class="product-mini__image"
                                         alt="@review.ProductName" />

                                    <div class="product-mini__info">

                                        <div class="product-mini__name">
                                            @review.ProductName
                                        </div>

                                        <div class="product-mini__hint">
                                            Click to open product details
                                        </div>
                                    </div>
                                </div>
                            </a>
                        </div>
                    </div>
                </article>
            }
        </div>

        @if (Model.TotalPages > 1)
        {
            <nav class="manage-reviews__pagination">

                <a class="pagination__link @(Model.HasPreviousPage ? "" : "is-disabled")"
                   asp-area="ControlPanel"
                   asp-controller="ControlPanelReview"
                   asp-action="Manage"
                   asp-route-page="@(Model.CurrentPage - 1)">
                    Previous
                </a>

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    bool isActive = i == Model.CurrentPage;

                    <a class="pagination__link @(isActive ? "is-active" : "")"
                       asp-area="ControlPanel"
                       asp-controller="ControlPanelReview"
                       asp-action="Manage"
                       asp-route-page="@i">
                        @i
                    </a>
                }

                <a class="pagination__link @(Model.HasNextPage ? "" : "is-disabled")"
                   asp-area="ControlPanel"
                   asp-controller="ControlPanelReview"
                   asp-action="Manage"
                   asp-route-page="@(Model.CurrentPage + 1)">
                    Next
                </a>
            </nav>
        }
    }
</section>


@section Styles {
    <link rel="stylesheet" href="~/css/ControlPanel/Review/manage.css" />
}

@section Scripts {
    <script src="~/js/ControlPanel/Review/manage.js"></script>
}