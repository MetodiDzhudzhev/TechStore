@using TechStore.Web.ViewModels.Product
@model DeleteProductViewModel

@{
    ViewData["Title"] = "Delete Product";
}

<section class="product-delete">

    <div class="product-delete__card">

        <h2 class="product-delete__question">
            Are you sure you want to delete this product?
        </h2>

        <h3 class="product-delete__name">
            @Model.Name
        </h3>

        <div class="product-delete__content">

            <div class="product-delete__image-wrapper">

                <img src="@(Model.ImageUrl ?? Url.Content("~/images/default-image.jpg"))"
                     alt="@Model.Name"
                     class="product-delete__image" />

            </div>

            <div class="product-delete__description-box">

                <p class="product-delete__description">
                    @Model.Description
                </p>
            </div>
        </div>

        <form asp-area="ControlPanel"
              asp-controller="ControlPanelProduct"
              asp-action="Delete"
              method="post"
              class="product-delete__actions">

            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="Name" />
            <input type="hidden" asp-for="Description" />
            <input type="hidden" asp-for="CategoryId" />
            <input type="hidden" asp-for="ImageUrl" />

            <a asp-area=""
               asp-controller="Product"
               asp-action="Details"
               asp-route-id="@Model.Id"
               class="product-delete__btn product-delete__btn--cancel">
                Cancel
            </a>

            <button type="submit"
                    class="product-delete__btn product-delete__btn--confirm">
                Confirm
            </button>
        </form>
    </div>
</section>

@section Styles {
    <link rel="stylesheet" href="~/css/ControlPanel/Product/delete.css" />
}