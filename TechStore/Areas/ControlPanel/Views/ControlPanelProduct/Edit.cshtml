@using TechStore.Web.ViewModels.Product
@model ProductFormInputModel

@{
    ViewData["Title"] = "Edit Product";
}

<section class="product-form">

    <div class="product-form__card">

        <header class="product-form__header">
            <h2 class="product-form__title">Edit product</h2>
        </header>

        <form asp-area="ControlPanel"
              asp-controller="ControlPanelProduct"
              asp-action="Edit"
              method="post"
              class="product-form__form">

            <input type="hidden" asp-for="Id" />

            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly"
                 class="product-form__validation"></div>

            <div class="product-form__field">

                <label asp-for="Name"
                       class="product-form__label"></label>

                <input asp-for="Name"
                       class="product-form__input" />

                <span asp-validation-for="Name"
                      class="product-form__error"></span>
            </div>

            <div class="product-form__field">

                <label asp-for="Description"
                       class="product-form__label"></label>

                    <textarea asp-for="Description"
                       class="product-form__textarea"></textarea>

                <span asp-validation-for="Description"
                      class="product-form__error"></span>
            </div>

            <div class="product-form__field">

                <label asp-for="ImageUrl"
                       class="product-form__label"></label>

                <input asp-for="ImageUrl"
                       class="product-form__input" />

                <span asp-validation-for="ImageUrl"
                      class="product-form__error"></span>
            </div>

            <div class="product-form__field">

                <label asp-for="Price"
                       class="product-form__label"></label>

                <input asp-for="Price"
                       class="product-form__input" />

                <span asp-validation-for="Price"
                      class="product-form__error"></span>
            </div>

            <div class="product-form__field">

                <label asp-for="QuantityInStock"
                       class="product-form__label">
                    Quantity in stock
                </label>

                <input asp-for="QuantityInStock"
                       class="product-form__input" />

                <span asp-validation-for="QuantityInStock"
                      class="product-form__error"></span>
            </div>

            <div class="product-form__field">

                <label asp-for="CategoryId"
                       class="product-form__label">
                    Category
                </label>

                <select asp-for="CategoryId"
                        class="product-form__select"
                        asp-items="@(new SelectList(Model.Categories, "Id", "Name"))">
                </select>

                <span asp-validation-for="CategoryId"
                      class="product-form__error"></span>
            </div>

            <div class="product-form__field">

                <label asp-for="BrandId"
                       class="product-form__label">
                    Brand
                </label>

                <select asp-for="BrandId"
                        class="product-form__select"
                        asp-items="@(new SelectList(Model.Brands, "Id", "Name"))">
                </select>

                <span asp-validation-for="BrandId"
                      class="product-form__error"></span>
            </div>

            <div class="product-form__actions">

                <a asp-area="ControlPanel"
                   asp-controller="ControlPanelProduct"
                   asp-action="Manage"
                   class="product-form__btn product-form__btn--back">
                    Back
                </a>

                <button type="submit"
                        class="product-form__btn product-form__btn--save">
                    Save changes
                </button>
            </div>
        </form>
    </div>
</section>

@section Styles {
    <link rel="stylesheet" href="~/css/ControlPanel/Product/product-form.css" />
}