@using TechStore.Web.ViewModels.Product
@model ProductFormInputModel

@{
    ViewData["Title"] = "Restore Product";
}

<section class="product-restore">

    <div class="product-restore__card">

        <h2 class="product-restore__title">
            Restore product
        </h2>

        <p class="product-restore__message">
            Product with the name
            <strong>@Model.Name</strong> already exists, but is deactivated.
            <br />
            Do you want to restore it?
        </p>

        @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
        {
            <div class="product-restore__image-wrapper">

                <img src="@Model.ImageUrl"
                     alt="@Model.Name"
                     class="product-restore__image" />
            </div>
        }

        <form asp-area="ControlPanel"
              asp-controller="ControlPanelProduct"
              asp-action="RestoreConfirmed"
              asp-route-id="@Model.Id"
              method="post"
              class="product-restore__actions">

            <input type="hidden" asp-for="Id" />

            @Html.AntiForgeryToken()

            <a asp-area="ControlPanel"
               asp-controller="ControlPanelProduct"
               asp-action="Manage"
               class="product-restore__btn product-restore__btn--cancel">
                Cancel
            </a>

            <button type="submit"
                    class="product-restore__btn product-restore__btn--restore">
                Yes, restore
            </button>
        </form>
    </div>
</section>

@section Styles {
    <link rel="stylesheet" href="~/css/ControlPanel/Product/restore.css" />
}