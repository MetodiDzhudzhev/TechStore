@using TechStore.Web.ViewModels.Product
@model ProductManageListViewModel

@{
    ViewData["Title"] = "Manage Products";
}

<section class="manage-products">

    <header class="manage-products__header">
        <h2 class="manage-products__title">Manage Products</h2>

        <a asp-action="Add"
           class="btn btn-add">
            <span>Add product</span>
        </a>
    </header>

    @if (Model.Products == null || !Model.Products.Any())
    {
        <div class="manage-products__empty">
            No products found.
        </div>
    }
    else
    {

        <div class="product-table">

            <div class="product-table__header">

                <span>Name</span>
                <span>Category</span>
                <span>Brand</span>
                <span>Price</span>
                <span>Stock</span>
                <span></span>
            </div>

            <div class="product-list">

                @foreach (var product in Model.Products)
                {
                    var collapseId = $"product-{product.Id}";

                    <article class="product-card">

                        <div class="product-card__summary js-product-toggle"
                             data-target="@collapseId">

                            <span class="product-card__name"
                                  data-label="Name">
                                @product.Name
                            </span>

                            <span class="product-card__category"
                                  data-label="Category">
                                @product.CategoryName
                            </span>

                            <span class="product-card__brand"
                                  data-label="Brand">
                                @product.BrandName
                            </span>

                            <span class="product-card__price"
                                  data-label="Price">
                                @product.Price.ToString("F2") €
                            </span>

                            <span class="product-card__stock"
                                  data-label="Stock">
                                @product.QuantityInStock
                            </span>

                            <div class="product-card__actions">

                                <a asp-area="ControlPanel"
                                   asp-controller="ControlPanelProduct"
                                   asp-action="Edit"
                                   asp-route-id="@product.Id"
                                   class="btn btn--edit">
                                    Edit
                                </a>

                                <a asp-area="ControlPanel"
                                   asp-controller="ControlPanelProduct"
                                   asp-action="Delete"
                                   asp-route-id="@product.Id"
                                   class="btn btn--delete">
                                    Delete
                                </a>
                            </div>
                        </div>

                        <div id="@collapseId" class="product-card__details">

                            <div class="product-details">

                                <div class="product-details__image">

                                    <img src="@(!string.IsNullOrWhiteSpace(product.ImageUrl)
                                                     ? product.ImageUrl
                                                     : Url.Content("~/images/default-image.jpg"))"
                                    alt="@product.Name" />
                                </div>

                                <div class="product-details__description">

                                    @if (!string.IsNullOrWhiteSpace(product.Description))
                                    {
                                        <div class="product-details__text">
                                            @product.Description
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="product-details__empty">
                                            No description available.
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </article>
                }
            </div>
        </div>

        @if (Model.TotalPages > 1)
        {
            <nav class="manage-products__pagination">

                <a class="pagination__link @(Model.HasPreviousPage ? "" : "is-disabled")"
                   asp-area="ControlPanel"
                   asp-controller="ControlPanelProduct"
                   asp-action="Manage"
                   asp-route-page="@(Model.CurrentPage - 1)">
                    Previous
                </a>

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    bool isActive = i == Model.CurrentPage;

                    <a class="pagination__link @(isActive ? "is-active" : "")"
                       asp-area="ControlPanel"
                       asp-controller="ControlPanelProduct"
                       asp-action="Manage"
                       asp-route-page="@i">
                        @i
                    </a>
                }

                <a class="pagination__link @(Model.HasNextPage ? "" : "is-disabled")"
                   asp-area="ControlPanel"
                   asp-controller="ControlPanelProduct"
                   asp-action="Manage"
                   asp-route-page="@(Model.CurrentPage + 1)">
                    Next
                </a>
            </nav>
        }
    }
</section>

@section Styles {
    <link rel="stylesheet" href="~/css/ControlPanel/Product/manage.css" />
}

@section Scripts {
    <script src="~/js/ControlPanel/Product/manage.js"></script>
}