@model TechStore.Web.ViewModels.Order.OrderEditPageViewModel
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = $"Edit Order #{Model.Id}";

    var allowedStatuses =
        ViewBag.AllowedStatuses as IEnumerable<SelectListItem>
        ?? Enumerable.Empty<SelectListItem>();

    bool hasAllowedStatuses = allowedStatuses.Any();
    bool canEditShipping = Model.CanEditShipping;
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert--success">
        @TempData["SuccessMessage"]
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert--error">
        @TempData["ErrorMessage"]
    </div>
}

<section class="edit-order">

    <header class="edit-order__header">

        <h2 class="edit-order__title">
            Edit order #@Model.Id
        </h2>
    </header>

    <section class="summary-card">

        <div class="summary-card__header">

            <div>
                <h3>Order summary</h3>
                <div class="summary-card__id">
                    Order #@Model.Id
                </div>
            </div>

            <div class="summary-card__info">

                <div class="summary-info">
                    <span class="summary-info__label">Payment</span>
                    <span class="summary-info__value">@Model.PaymentMethod</span>
                </div>

                <div class="summary-info">
                    <span class="summary-info__label">Status</span>
                    <span class="status status--@Model.CurrentStatus.ToString().ToLower()">
                        @Model.CurrentStatus
                    </span>
                </div>

                <div class="summary-info">
                    <span class="summary-info__label">Order date</span>
                    <span class="summary-info__value">@Model.OrderDate</span>
                </div>

                <div class="summary-info">
                    <span class="summary-info__label">Total</span>
                    <span class="summary-info__total">@Model.TotalSum.ToString("F2") €</span>
                </div>
            </div>
        </div>
    </section>

    <div class="edit-order__grid">

        <section class="edit-card">

            <header class="edit-card__header">

                <h4>Status</h4>

                @if (hasAllowedStatuses)
                {
                    <span class="badge badge--editable">editable</span>
                }
                else
                {
                    <span class="badge badge--locked">locked</span>
                }

            </header>

            @if (!hasAllowedStatuses)
            {
                <div class="info-box">
                    No status changes are available for orders that are
                    <strong>@Model.CurrentStatus.ToString().ToLower()</strong>.
                </div>
            }

            <form asp-area="ControlPanel"
                  asp-controller="ControlPanelOrder"
                  asp-action="ChangeStatus"
                  method="post"
                  class="form">

                @Html.AntiForgeryToken()

                <input asp-for="Status.Id" type="hidden" />

                <div class="form__group">


                    @if (hasAllowedStatuses)
                    {
                        <label>New status</label>

                        <select asp-for="Status.NewStatus"
                                asp-items="allowedStatuses"
                                class="form__input">
                        </select>

                        <span asp-validation-for="Status.NewStatus"
                              class="form__error"></span>

                        <div class="form__hint">
                            Only valid next statuses are shown.
                        </div>
                    }
                    else
                    {
                        <input asp-for="Status.NewStatus" type="hidden" />
                    }
                </div>

                <button type="submit"
                        class="btn btn--primary"
                        disabled="@(hasAllowedStatuses ? null : "disabled")">
                    Update status
                </button>
            </form>
        </section>

        <section class="edit-card">

            <header class="edit-card__header">

                <h4>Shipping details</h4>

                @if (canEditShipping)
                {
                    <span class="badge badge--editable">editable</span>
                }
                else
                {
                    <span class="badge badge--locked">locked</span>
                }
            </header>

            @if (!canEditShipping)
            {
                <div class="info-box">
                    Shipping details are locked because the order is
                    <strong>@Model.CurrentStatus.ToString().ToLower()</strong>.
                </div>
            }

            <form asp-area="ControlPanel"
                  asp-controller="ControlPanelOrder"
                  asp-action="EditShipping"
                  method="post"
                  class="form">

                @Html.AntiForgeryToken()

                <input asp-for="Shipping.Id" type="hidden" />

                <div class="form-grid">

                    <div class="form__group">
                        <label asp-for="Shipping.RecipientName"></label>
                        <input asp-for="Shipping.RecipientName"
                               class="form__input"
                               readonly="@(canEditShipping ? null : "readonly")" />
                        <span asp-validation-for="Shipping.RecipientName"
                              class="form__error"></span>
                    </div>

                    <div class="form__group">
                        <label asp-for="Shipping.PhoneNumber"></label>
                        <input asp-for="Shipping.PhoneNumber"
                               class="form__input"
                               readonly="@(canEditShipping ? null : "readonly")" />
                        <span asp-validation-for="Shipping.PhoneNumber"
                              class="form__error"></span>
                    </div>

                    <div class="form__group form__group--full">
                        <label asp-for="Shipping.Email"></label>
                        <input asp-for="Shipping.Email"
                               class="form__input"
                               readonly="@(canEditShipping ? null : "readonly")" />
                    </div>

                    <div class="form__group form__group--full">
                        <label asp-for="Shipping.ShippingAddress"></label>
                        <textarea asp-for="Shipping.ShippingAddress"
                            rows="3"
                            class="form__input"
                            readonly="@(canEditShipping ? null : "readonly")"></textarea>
                    </div>
                </div>

                <button type="submit"
                        class="btn btn--primary"
                        disabled="@(canEditShipping ? null : "disabled")">
                        Update shipping details
                </button>
            </form>
        </section>
    </div>
</section>

@section Styles {
    <link rel="stylesheet" href="~/css/ControlPanel/Order/edit.css" />
}