@using TechStore.Web.ViewModels.Order
@model OrderManageListViewModel

@{
    ViewData["Title"] = "Manage Orders";
}

<section class="manage-orders">

    <header class="manage-orders__header">
        <h2 class="manage-orders__title">Manage Orders</h2>
    </header>

    @if (!Model.Orders.Any())
    {
        <div class="manage-orders__empty">
            No orders found.
        </div>
    }
    else
    {
        <div class="manage-orders__list">

            @foreach (var order in Model.Orders)
            {
                var detailsId = $"order-{order.Id}";

                <article class="order-card">

                    <div class="order-card__summary">

                        <div class="order-card__meta">

                            <span class="order-card__id">
                                Order #@order.Id
                            </span>

                            <span class="order-card__date">
                                @order.Date
                            </span>

                            <span class="order-card__status order-card__status--@order.Status.ToLower()">
                                @order.Status
                            </span>

                            <span class="order-card__separator">|</span>

                            <span class="order-card__email">
                                @order.Email
                            </span>

                            <span class="order-card__total">
                                Total: @order.TotalSum.ToString("F2") €
                            </span>
                        </div>

                        <div class="order-card__actions">
                            <button type="button"
                                    class="order-card__btn order-card__btn--details js-toggle-details"
                                    data-target="@detailsId">
                                Details
                            </button>

                            <a class="order-card__btn order-card__btn--edit"
                               asp-area="ControlPanel"
                               asp-controller="ControlPanelOrder"
                               asp-action="Edit"
                               asp-route-id="@order.Id">
                                Edit
                            </a>
                        </div>
                    </div>

                    <div id="@detailsId" class="order-card__details">

                        <div class="order-card__grid">

                            <div class="order-card__column">
                                <div class="order-card__label">Recipient</div>
                                <div class="order-card__value">@order.RecipientName</div>

                                <div class="order-card__label">Address</div>
                                <div class="order-card__value">@order.ShippingAddress</div>

                                <div class="order-card__label">Phone</div>
                                <div class="order-card__value">@order.PhoneNumber</div>
                            </div>

                            <div class="order-card__column">
                                <div class="order-card__label">Payment method</div>
                                <div class="order-card__value">@order.PaymentMethod</div>

                                <div class="order-card__label">Email</div>
                                <div class="order-card__value">@order.Email</div>
                            </div>
                        </div>

                        <hr class="order-card__divider" />

                        <div class="order-card__items-title">Items</div>

                        @if (!order.Products.Any())
                        {
                            <div class="order-card__no-products">
                                No products for this order.
                            </div>
                        }
                        else
                        {
                            <div class="order-items">
                                @foreach (var p in order.Products)
                                {
                                    <div class="order-item">

                                        <div class="order-item__image">
                                            <img src="@(!string.IsNullOrWhiteSpace(p.ImageUrl) ? p.ImageUrl : Url.Content("~/images/default-image.jpg"))"
                                                 alt="@p.ProductName" />
                                        </div>

                                        <div class="order-item__content">

                                            <div class="order-item__title">
                                                @p.ProductName
                                            </div>

                                            @if (!string.IsNullOrWhiteSpace(p.Description))
                                            {
                                                <div class="order-item__description">
                                                    @p.Description
                                                </div>
                                            }

                                            <div class="order-item__badges">
                                                <span class="order-item__badge">
                                                    Qty: @p.Quantity
                                                </span>
                                                <span class="order-item__badge">
                                                    Unit price: @p.Price.ToString("F2") €
                                                </span>
                                                <span class="order-item__badge">
                                                    Total: @p.TotalSum.ToString("F2") €
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </article>
            }
        </div>

        <nav class="manage-orders__pagination">

            <a class="pagination__link @(Model.HasPreviousPage ? "" : "is-disabled")"
               asp-action="Manage"
               asp-route-page="@(Model.CurrentPage - 1)">
                Previous
            </a>

            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                bool isActive = i == Model.CurrentPage;

                <a class="pagination__link @(isActive ? "is-active" : "")"
                   asp-action="Manage"
                   asp-route-page="@i">
                    @i
                </a>
            }

            <a class="pagination__link @(Model.HasNextPage ? "" : "is-disabled")"
               asp-action="Manage"
               asp-route-page="@(Model.CurrentPage + 1)">
                Next
            </a>

        </nav>
    }

</section>

@section Styles {
    <link rel="stylesheet" href="~/css/ControlPanel/Order/manage.css" />
}

@section Scripts {
    <script src="~/js/ControlPanel/Order/manage.js"></script>
}