@using TechStore.Web.ViewModels.Brand
@model BrandFormInputViewModel

@{
    ViewData["Title"] = "Edit Brand";
}

<section class="brand-form">

    <div class="brand-form__card">

        <header class="brand-form__header">
            <h2 class="brand-form__title">Edit brand</h2>
        </header>

        <form asp-area="ControlPanel"
              asp-controller="ControlPanelBrand"
              asp-action="Edit"
              method="post"
              class="brand-form__form">

            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly"
                 class="brand-form__validation"></div>

            <input type="hidden" asp-for="Id" />

            <div class="brand-form__field">

                <label asp-for="Name"
                       class="brand-form__label"></label>

                <input asp-for="Name"
                       class="brand-form__input" />

                <span asp-validation-for="Name"
                      class="brand-form__error"></span>
            </div>

            <div class="brand-form__field">

                <label asp-for="LogoUrl"
                       class="brand-form__label">
                    Logo URL (optional)
                </label>

                <input asp-for="LogoUrl"
                       class="brand-form__input" />

                <span asp-validation-for="LogoUrl"
                      class="brand-form__error"></span>
            </div>

            <div class="brand-form__field">

                <label asp-for="Description"
                       class="brand-form__label"></label>

                <textarea asp-for="Description"
                          class="brand-form__textarea"></textarea>

                <span asp-validation-for="Description"
                      class="brand-form__error"></span>
            </div>

            <div class="brand-form__actions">

                <a asp-area="ControlPanel"
                   asp-controller="ControlPanelBrand"
                   asp-action="Manage"
                   class="brand-form__btn brand-form__btn--back">
                    <span>Back</span>
                </a>

                <button type="submit"
                        class="brand-form__btn brand-form__btn--save">
                    <span>Save changes</span>
                </button>
            </div>
        </form>
    </div>
</section>

@section Styles {
    <link rel="stylesheet" href="~/css/ControlPanel/Brand/brand-form.css" />
}