@using TechStore.Web.ViewModels.Brand
@model BrandManageListViewModel

@{
    ViewData["Title"] = "Manage Brands";
}

<section class="manage-brands">

    <header class="manage-brands__header">

        <h2 class="manage-brands__title">Manage Brands</h2>

        <a asp-action="Add" class="manage-brands__add-btn">
            <span>Add Brand</span>
        </a>
    </header>

    <div class="brand-grid">

        @foreach (var brand in Model.Brands)
        {
            <article class="brand-card">

                <a asp-area=""
                   asp-controller="Brand"
                   asp-action="Details"
                   asp-route-id="@brand.Id"
                   class="brand-card__image-link">

                    <img src="@brand.LogoUrl"
                         alt="@brand.Name"
                         class="brand-card__image" />
                </a>

                <div class="brand-card__actions">

                    <a asp-area="ControlPanel"
                       asp-controller="ControlPanelBrand"
                       asp-action="Edit"
                       asp-route-brandId="@brand.Id"
                       class="brand-card__btn brand-card__btn--edit">
                        <i class="bi bi-pencil"></i>
                    </a>

                    <a asp-area="ControlPanel"
                       asp-controller="ControlPanelBrand" 
                       asp-action="Delete"
                       asp-route-id="@brand.Id"
                       class="brand-card__btn brand-card__btn--delete">
                        <i class="bi bi-trash"></i>
                    </a>
                </div>
            </article>
        }
    </div>
</section>

@section Styles {
    <link rel="stylesheet" href="~/css/ControlPanel/Brand/manage.css" />
}