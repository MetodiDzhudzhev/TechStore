@using TechStore.Web.ViewModels.Brand
@model DeleteBrandViewModel

@{
    ViewData["Title"] = "Delete Brand";
}

<section class="brand-delete">

    <div class="brand-delete__card">

        <h2 class="brand-delete__question">
            Are you sure you want to delete this brand?
        </h2>

        <h3 class="brand-delete__name">
            @Model.Name
        </h3>

        <div class="brand-delete__content">

            <div class="brand-delete__image-wrapper">

                <img src="@(Model.LogoUrl ?? Url.Content("~/images/default-image.jpg"))"
                     alt="@Model.Name"
                     class="brand-delete__image" />
            </div>

            <div class="brand-delete__description-box">

                @if (!string.IsNullOrWhiteSpace(Model.Description))
                {
                    <p class="brand-delete__description">
                        @Model.Description
                    </p>
                }
                else
                {
                    <p class="brand-delete__description brand-delete__description--empty">
                        No description available.
                    </p>
                }
            </div>
        </div>

        <form asp-area="ControlPanel"
              asp-controller="ControlPanelBrand"
              asp-action="Delete"
              method="post"
              class="brand-delete__actions">

            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="Name" />
            <input type="hidden" asp-for="LogoUrl" />
            <input type="hidden" asp-for="Description" />

            <a asp-area="ControlPanel"
               asp-controller="ControlPanelBrand"
               asp-action="Manage"
               class="brand-delete__btn brand-delete__btn--cancel">
                Cancel
            </a>

            <button type="submit"
                    class="brand-delete__btn brand-delete__btn--confirm">
                Confirm
            </button>
        </form>
    </div>
</section>

@section Styles {
    <link rel="stylesheet" href="~/css/ControlPanel/Brand/delete.css" />
}