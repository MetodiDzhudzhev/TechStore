@using TechStore.Web.ViewModels.Category
@model CategoryFormInputViewModel

@{
    ViewData["Title"] = "Edit Category";
}

<section class="category-form">

    <div class="category-form__card">

        <header class="category-form__header">
            <h2 class="category-form__title">Edit category</h2>
        </header>

        <form asp-area="ControlPanel"
              asp-controller="ControlPanelCategory"
              asp-action="Edit"
              method="post"
              class="category-form__form">

            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly"
                 class="category-form__validation"></div>

            <input type="hidden" asp-for="Id" />

            <div class="category-form__field">

                <label asp-for="Name"
                       class="category-form__label"></label>

                <input asp-for="Name"
                       class="category-form__input" />

                <span asp-validation-for="Name"
                      class="category-form__error"></span>
            </div>

            <div class="category-form__field">

                <label asp-for="ImageUrl"
                    class="category-form__label">
                    Image URL (optional)
                </label>

                <input asp-for="ImageUrl"
                       class="category-form__input" />

                <span asp-validation-for="ImageUrl"
                      class="category-form__error"></span>
            </div>

            <div class="category-form__actions">

                <a asp-area="ControlPanel"
                   asp-controller="ControlPanelCategory"
                   asp-action="Manage"
                   class="category-form__btn category-form__btn--back">
                    <span>Back</span>
                </a>

                <button type="submit"
                        class="category-form__btn category-form__btn--save">
                    <span>Save changes</span>
                </button>
            </div>
        </form>
    </div>
</section>

@section Styles {
    <link rel="stylesheet" href="~/css/ControlPanel/Category/category-form.css" />
}