@using TechStore.Web.ViewModels.Category
@model CategoryFormInputViewModel

@{
    ViewData["Title"] = "Restore Category";
}

<section class="category-restore">

    <div class="category-restore__card">

        <h2 class="category-restore__title">
            Restore category
        </h2>

        <p class="category-restore__message">
            Category with the name
            <strong>@Model.Name</strong> already exists, but is deactivated.
            <br />
            Do you want to restore it?
        </p>

        @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
        {
            <div class="category-restore__image-wrapper">

                <img src="@Model.ImageUrl"
                     alt="@Model.Name"
                     class="category-restore__image" />
            </div>
        }

        <form asp-area="ControlPanel"
              asp-controller="ControlPanelCategory"
              asp-action="RestoreConfirmed"
              asp-route-id="@Model.Id"
              method="post"
              class="category-restore__actions">

            <input type="hidden" asp-for="Id" />

            @Html.AntiForgeryToken()

            <a asp-area="ControlPanel"
               asp-controller="ControlPanelCategory"
               asp-action="Add"
               class="category-restore__btn category-restore__btn--cancel">
                Cancel
            </a>

            <button type="submit"
                    class="category-restore__btn category-restore__btn--restore">
                Yes, restore
            </button>
        </form>
    </div>
</section>

@section Styles {
    <link rel="stylesheet" href="~/css/ControlPanel/Category/restore.css" />
}