@using TechStore.Web.ViewModels.Category
@model DeleteCategoryViewModel

@{
    ViewData["Title"] = "Delete Category";
}

<section class="category-delete">

    <div class="category-delete__card">

        <h2 class="category-delete__question">
            Are you sure you want to delete this category?
        </h2>

        <h3 class="category-delete__name">
            @Model.Name
        </h3>

        <div class="category-delete__content">

            <div class="category-delete__image-wrapper">

                <img src="@(Model.ImageUrl ?? Url.Content("~/images/default-image.jpg"))"
                     alt="@Model.Name"
                     class="category-delete__image" />
            </div>
        </div>

        <form asp-area="ControlPanel"
              asp-controller="ControlPanelCategory"
              asp-action="Delete"
              method="post"
              class="category-delete__actions">

            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="Name" />
            <input type="hidden" asp-for="ImageUrl" />

            <a asp-area="ControlPanel"
               asp-controller="ControlPanelCategory"
               asp-action="Manage"
               class="category-delete__btn category-delete__btn--cancel">
                Cancel
            </a>

            <button type="submit"
                    class="category-delete__btn category-delete__btn--confirm">
                Confirm
            </button>
        </form>
    </div>
</section>

@section Styles {
    <link rel="stylesheet" href="~/css/ControlPanel/Category/delete.css" />
}