@using TechStore.Web.ViewModels.User
@model UserManageListViewModel

@{
    ViewData["Title"] = "Manage Users";
}

<section class="manage-users">

    <header class="manage-users__header">

        <h2 class="manage-users__title">
            Manage Users
        </h2>

    </header>

        <div class="user-table">

            <div class="user-table__header">

                <span>Email</span>
                <span>Full name</span>
                <span>Current role</span>
                <span>Change role</span>

            </div>


            <div class="user-list">

                @foreach (var user in Model.Users)
                {

                    <article class="user-row">

                        <div class="user-row__email"
                             data-label="Email">
                            @user.Email
                        </div>

                        <div class="user-row__name"
                             data-label="Full name">
                            @user.FullName
                        </div>

                        <div class="user-row__roles"
                             data-label="Current role">

                            @foreach (var role in user.Roles)
                            {
                                <span class="role-badge role-badge--@role.ToLower()">
                                    @role
                                </span>
                            }
                        </div>

                        <div class="user-row__actions"
                             data-label="Change role">

                            <form asp-action="AssignRole"
                                  method="post"
                                  class="user-role-form">

                                @Html.AntiForgeryToken()

                                <input type="hidden" name="userId" value="@user.Id" />
                                <input type="hidden" name="currentPage" value="@Model.CurrentPage" />

                                <select name="selectedRole"
                                        class="user-role-form__select"
                                        required>

                                    <option disabled selected>Select role</option>

                                    @foreach (var role in Model.AllRoles)
                                    {
                                        <option value="@role">@role</option>
                                    }
                                </select>

                                <button type="submit"
                                        class="user-role-form__btn">
                                    Apply
                                </button>
                            </form>
                        </div>
                    </article>
                }
            </div>
        </div>

        @if (Model.TotalPages > 1)
        {
            <nav class="manage-users__pagination">

                <a class="pagination__link @(Model.CurrentPage == 1 ? "is-disabled" : "")"
                   asp-action="Manage"
                   asp-route-page="@(Model.CurrentPage - 1)">
                    Previous
                </a>

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    bool isActive = i == Model.CurrentPage;

                    <a class="pagination__link @(isActive ? "is-active" : "")"
                       asp-action="Manage"
                       asp-route-page="@i">
                        @i
                    </a>
                }

                <a class="pagination__link @(Model.CurrentPage == Model.TotalPages ? "is-disabled" : "")"
                   asp-action="Manage"
                   asp-route-page="@(Model.CurrentPage + 1)">
                    Next
                </a>
            </nav>
        }
</section>

@section Styles {
    <link rel="stylesheet" href="~/css/ControlPanel/User/manage.css" />
}