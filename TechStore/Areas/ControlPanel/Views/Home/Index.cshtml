@{
    ViewData["Title"] = "Control Panel";
    bool isManager = User.IsInRole("Manager");
}

<section class="cp">

    <header class="cp__header">
        <h1 class="cp__title">
            Welcome to the Control Panel
        </h1>
        <p class="cp__subtitle">
            Manage your store using the sections below:
        </p>
    </header>

    <div class="cp__row cp__row--top">

        <article class="cp-card">
            <div class="cp-card__body">
                <i class="bi bi-tags-fill cp-card__icon cp-card__icon--warning"></i>
                <h5 class="cp-card__title">Manage Categories</h5>
                <p class="cp-card__text">Add, edit or delete categories.</p>
                <a asp-area="ControlPanel"
                   asp-controller="ControlPanelCategory"
                   asp-action="Manage"
                   class="cp-card__btn cp-card__btn--warning">
                    Go to Categories
                    <i class="bi bi-arrow-right-circle"></i>
                </a>
            </div>
        </article>

        <article class="cp-card">
            <div class="cp-card__body">
                <i class="bi bi-box-seam cp-card__icon cp-card__icon--success"></i>
                <h5 class="cp-card__title">Manage Products</h5>
                <p class="cp-card__text">Add, edit or delete products.</p>
                <a asp-area="ControlPanel"
                   asp-controller="ControlPanelProduct"
                   asp-action="Manage"
                   class="cp-card__btn cp-card__btn--success">
                    Go to Products
                    <i class="bi bi-arrow-right-circle"></i>
                </a>
            </div>
        </article>
    </div>

    <div class="cp__row cp__row--bottom">

        <article class="cp-card">
            <div class="cp-card__body">
                <i class="bi bi-star-fill cp-card__icon cp-card__icon--primary"></i>
                <h5 class="cp-card__title">Manage Brands</h5>
                <p class="cp-card__text">Add, edit or delete brands.</p>
                <a asp-area="ControlPanel"
                   asp-controller="ControlPanelBrand"
                   asp-action="Manage"
                   class="cp-card__btn cp-card__btn--primary">
                    Go to Brands
                    <i class="bi bi-arrow-right-circle"></i>
                </a>
            </div>
        </article>

        <article class="cp-card">
            <div class="cp-card__body">
                <i class="bi bi-receipt cp-card__icon cp-card__icon--purple"></i>
                <h5 class="cp-card__title">Manage Orders</h5>
                <p class="cp-card__text">Manage customer orders.</p>
                <a asp-area="ControlPanel"
                   asp-controller="ControlPanelOrder"
                   asp-action="Manage"
                   class="cp-card__btn cp-card__btn--purple">
                    Go to Orders
                    <i class="bi bi-arrow-right-circle"></i>
                </a>
            </div>
        </article>

        <article class="cp-card">
            <div class="cp-card__body">
                <i class="bi bi-chat-square-text-fill cp-card__icon cp-card__icon--danger"></i>
                <h5 class="cp-card__title">Manage Reviews</h5>
                <p class="cp-card__text">Manage customer reviews.</p>
                <a asp-area="ControlPanel"
                   asp-controller="ControlPanelReview"
                   asp-action="Manage"
                   class="cp-card__btn cp-card__btn--danger">
                    Go to Reviews
                    <i class="bi bi-arrow-right-circle"></i>
                </a>
            </div>
        </article>

        @if (isManager)
        {
            <article class="cp-card">
                <div class="cp-card__body">
                    <i class="bi bi-people-fill cp-card__icon cp-card__icon--info"></i>
                    <h5 class="cp-card__title">Manage Users</h5>
                    <p class="cp-card__text">Manage users and assign roles.</p>
                    <a asp-area="ControlPanel"
                       asp-controller="ControlPanelUser"
                       asp-action="Manage"
                       class="cp-card__btn cp-card__btn--info">
                        Go to Users
                        <i class="bi bi-arrow-right-circle"></i>
                    </a>
                </div>
            </article>
        }
    </div>

</section>

@section Styles {
    <link rel="stylesheet" href="~/css/ControlPanel/Home/index.css" />
}